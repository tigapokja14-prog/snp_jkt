---
// src/pages/index.astro
import DashboardLayout from "../layouts/DashboardLayout.astro";
import {
  getSNPData,
  avgByKabupaten,
  akreditasiDistribusi,
  statusANDistribusi,
  rankingSekolah,
  statusAlokasiDistribusi,
} from "../lib/googleSheets";

const data = await getSNPData();
const activeData = data.filter((s) => s.snp > 0);
const kabData = avgByKabupaten(data);
const akreditasi = akreditasiDistribusi(data);
const statusAN = statusANDistribusi(data);
const statusAlokasi = statusAlokasiDistribusi(data);
const topSekolah = rankingSekolah(data, true, 5);

const avgSNP =
  activeData.length > 0
    ? (activeData.reduce((s, d) => s + d.snp, 0) / activeData.length).toFixed(1)
    : "0";

const standarLabels = [
  { key: "standarIsi", label: "Standar Isi", short: "Isi", color: "#2563EB" },
  {
    key: "standarKelulusan",
    label: "Standar Kelulusan",
    short: "Kelulusan",
    color: "#0891B2",
  },
  {
    key: "standarPengelolaan",
    label: "Standar Pengelolaan",
    short: "Pengelolaan",
    color: "#7C3AED",
  },
  {
    key: "standarPenilaian",
    label: "Standar Penilaian",
    short: "Penilaian",
    color: "#059669",
  },
  {
    key: "standarProses",
    label: "Standar Proses",
    short: "Proses",
    color: "#D97706",
  },
  {
    key: "standarSarpras",
    label: "Standar Sarpras",
    short: "Sarpras",
    color: "#DC2626",
  },
  { key: "standarPtk", label: "Standar PTK", short: "PTK", color: "#DB2777" },
  {
    key: "standarBiaya",
    label: "Standar Biaya",
    short: "Biaya",
    color: "#EA580C",
  },
];

const avgStandar = standarLabels.map((s) => ({
  ...s,
  avg:
    activeData.length > 0
      ? (
          activeData.reduce((sum, d) => sum + (d as any)[s.key], 0) /
          activeData.length
        ).toFixed(1)
      : "0",
}));

function snpColor(v: number) {
  if (v >= 75) return "#059669";
  if (v >= 60) return "#D97706";
  return "#DC2626";
}
---

<DashboardLayout title="Overview" activeMenu="overview">
  <!-- KPI row -->
  <div class="grid-4 mb-6 fade-up">
    <div class="kpi">
      <div class="kpi-label">Total Sekolah</div>
      <div class="kpi-value">{data.length}</div>
      <div class="kpi-sub">Sekolah SD terdaftar</div>
    </div>
    <div class="kpi d1 fade-up">
      <div class="kpi-label">Rata-rata SNP</div>
      <div class="kpi-value" style="color:var(--accent)">{avgSNP}</div>
      <div class="kpi-sub">{activeData.length} sekolah aktif</div>
    </div>
    <div class="kpi d2 fade-up">
      <div class="kpi-label">Ikut Asesmen</div>
      <div class="kpi-value">{statusAN.ikut}</div>
      <div class="kpi-sub">
        {((statusAN.ikut / statusAN.total) * 100).toFixed(0)}% partisipasi AN
      </div>
    </div>
    <div class="kpi d3 fade-up">
      <div class="kpi-label">Akreditasi A</div>
      <div class="kpi-value">{akreditasi["A"] || 0}</div>
      <div class="kpi-sub">Sekolah akreditasi A</div>
    </div>

    <div class="kpi d3 fade-up">
      <div class="kpi-label">Status alokasi</div>
      <div class="kpi-value">{statusAlokasi["Sudah Sesuai"] || 0}</div>
      <div class="kpi-sub">Status alokasi</div>
    </div>
  </div>

  <!-- Radar + Standar breakdown -->
  <div class="grid-2 mb-6 fade-up d2">
    <div class="card">
      <div class="card-header">
        <div class="card-title">Radar 8 Standar SNP</div>
        <span class="badge badge-blue">Rata-rata keseluruhan</span>
      </div>
      <div style="position:relative;height:300px">
        <canvas id="radarMain"></canvas>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Capaian Per Standar</div>
      <div style="display:flex;flex-direction:column;gap:13px">
        {
          avgStandar.map((s) => (
            <div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px">
                <span style="font-size:13px;color:var(--text-secondary)">
                  {s.label}
                </span>
                <span
                  class="mono"
                  style={`font-size:13px;font-weight:600;color:${s.color}`}
                >
                  {s.avg}
                </span>
              </div>
              <div class="progress-bar">
                <div
                  class="progress-fill"
                  style={`width:${s.avg}%;background:${s.color};opacity:0.75`}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Kabupaten + Top sekolah -->
  <div class="grid-2 mb-6 fade-up d3">
    <div class="card">
      <div class="card-title">SNP per Wilayah</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        {
          kabData
            .sort((a, b) => b.avgSNP - a.avgSNP)
            .map((kab, i) => (
              <div style="display:flex;align-items:center;gap:12px">
                <span style="font-size:12px;color:var(--text-tertiary);width:16px;text-align:right;flex-shrink:0">
                  {i + 1}
                </span>
                <div style="flex:1;min-width:0">
                  <div style="display:flex;justify-content:space-between;margin-bottom:4px">
                    <span style="font-size:13px;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                      {kab.kabupaten.replace("Kota Adm. ", "")}
                    </span>
                    <span
                      class="mono"
                      style={`font-size:13px;font-weight:600;margin-left:8px;flex-shrink:0;color:${snpColor(kab.avgSNP)}`}
                    >
                      {kab.avgSNP.toFixed(1)}
                    </span>
                  </div>
                  <div class="progress-bar">
                    <div
                      class="progress-fill"
                      style={`width:${kab.avgSNP}%;background:var(--accent)`}
                    />
                  </div>
                  <div style="font-size:11px;color:var(--text-tertiary);margin-top:2px">
                    {kab.count} sekolah aktif
                  </div>
                </div>
              </div>
            ))
        }
      </div>
    </div>

    <div class="card">
      <div class="card-title">Top 5 Sekolah</div>
      <div>
        {
          topSekolah.map((s, i) => (
            <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-light)">
              <div
                style={`width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0;${
                  i === 0
                    ? "background:#FEF9C3;color:#854D0E"
                    : i === 1
                      ? "background:#F1F5F9;color:#475569"
                      : i === 2
                        ? "background:#FFF7ED;color:#9A3412"
                        : "background:var(--bg-subtle);color:var(--text-tertiary)"
                }`}
              >
                {i + 1}
              </div>
              <div style="flex:1;min-width:0">
                <div style="font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                  {s.namaSekolah}
                </div>
                <div style="font-size:11px;color:var(--text-tertiary)">
                  {s.kabupaten.replace("Kota Adm. ", "")}
                </div>
              </div>
              <span
                class="mono"
                style={`font-size:14px;font-weight:600;flex-shrink:0;color:${snpColor(s.snp)}`}
              >
                {s.snp.toFixed(1)}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Distribusi akreditasi + Status AN -->
  <div class="grid-2 fade-up d4">
    <div class="card">
      <div class="card-title">Distribusi Akreditasi</div>
      <div style="position:relative;height:200px">
        <canvas id="chartAk"></canvas>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Status Asesmen Nasional</div>
      <div style="position:relative;height:200px">
        <canvas id="chartAN"></canvas>
      </div>
    </div>
  </div>
</DashboardLayout>

<script
  src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"
></script>
<script define:vars={{ avgStandar, akreditasi, statusAN }}>
  const TOOLTIP = {
    backgroundColor: "#fff",
    borderColor: "#E8EAEE",
    borderWidth: 1,
    titleColor: "#111827",
    bodyColor: "#4B5563",
    padding: 10,
    cornerRadius: 8,
    boxShadow: "0 4px 12px rgba(0,0,0,0.08)",
  };

  function initCharts() {
    if (typeof Chart === "undefined") {
      setTimeout(initCharts, 50);
      return;
    }

    // Radar
    new Chart(document.getElementById("radarMain"), {
      type: "radar",
      data: {
        labels: avgStandar.map((s) => s.short),
        datasets: [
          {
            label: "Rata-rata",
            data: avgStandar.map((s) => parseFloat(s.avg)),
            borderColor: "#2563EB",
            backgroundColor: "rgba(37,99,235,0.08)",
            pointBackgroundColor: "#2563EB",
            pointBorderColor: "#fff",
            pointBorderWidth: 2,
            borderWidth: 2,
            pointRadius: 4,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            ...TOOLTIP,
            callbacks: {
              label: (ctx) => ` ${avgStandar[ctx.dataIndex].label}: ${ctx.raw}`,
            },
          },
        },
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: {
              stepSize: 25,
              color: "#9CA3AF",
              backdropColor: "transparent",
              font: { size: 10 },
            },
            grid: { color: "#E8EAEE" },
            pointLabels: { color: "#6B7280", font: { size: 11 } },
            angleLines: { color: "#E8EAEE" },
          },
        },
      },
    });

    // Akreditasi
    const akKeys = Object.keys(akreditasi);
    const akColors = {
      A: "#2563EB",
      B: "#0891B2",
      C: "#D97706",
      "Tidak diisi": "#9CA3AF",
    };
    new Chart(document.getElementById("chartAk"), {
      type: "doughnut",
      data: {
        labels: akKeys,
        datasets: [
          {
            data: akKeys.map((k) => akreditasi[k]),
            backgroundColor: akKeys.map((k) => akColors[k] || "#9CA3AF"),
            borderColor: "#fff",
            borderWidth: 3,
            hoverOffset: 4,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: "65%",
        plugins: {
          legend: {
            position: "right",
            labels: {
              color: "#4B5563",
              font: { size: 12 },
              padding: 14,
              boxWidth: 10,
              borderRadius: 3,
            },
          },
          tooltip: TOOLTIP,
        },
      },
    });

    // Status AN
    new Chart(document.getElementById("chartAN"), {
      type: "doughnut",
      data: {
        labels: ["Ikut AN", "Tidak Ikut"],
        datasets: [
          {
            data: [statusAN.ikut, statusAN.tidak],
            backgroundColor: ["#059669", "#E5E7EB"],
            borderColor: "#fff",
            borderWidth: 3,
            hoverOffset: 4,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: "65%",
        plugins: {
          legend: {
            position: "right",
            labels: {
              color: "#4B5563",
              font: { size: 12 },
              padding: 14,
              boxWidth: 10,
              borderRadius: 3,
            },
          },
          tooltip: TOOLTIP,
        },
      },
    });
  }

  if (document.readyState === "loading")
    document.addEventListener("DOMContentLoaded", initCharts);
  else initCharts();
</script>
