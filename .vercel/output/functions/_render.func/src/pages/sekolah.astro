---
// src/pages/sekolah.astro
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { getSNPData } from "../lib/googleSheets";

const data = await getSNPData();
const kabList = [
  ...new Set(data.map((s) => s.kabupaten.replace("Kota Adm. ", ""))),
].sort();
const jenjangList = [
  ...new Set(data.map((s) => s.jenjang).filter(Boolean)),
].sort();

const sekolahData = data.map((s) => ({
  npsn: s.npsn,
  nama: s.namaSekolah,
  jenjang: s.jenjang,
  kab: s.kabupaten.replace("Kota Adm. ", ""),
  kec: s.kecamatan.replace("Kec. ", ""),
  akreditasi: s.akreditasi,
  siswa: s.siswa,
  snp: +s.snp.toFixed(2),
  statusAN: s.statusAN,
  statusLogin: s.statusLogin,
  statusUnduh: s.statusUnduh,
  statusAlokasi: s.statusAlokasi,
  menerapkanPMP: s.menerapkanPMP ?? (s as any)["Menerapkan PMP"] ?? "",
}));
---

<DashboardLayout title="Data Sekolah" activeMenu="sekolah">
  <!-- Filter Jenjang -->
  <div
    style="display:flex;align-items:center;gap:10px;margin-bottom:16px"
    class="fade-up"
  >
    <span style="font-size:13px;font-weight:600;color:var(--text-secondary)"
      >Jenjang:</span
    >
    <div style="display:flex;gap:6px;flex-wrap:wrap" id="jenjangFilter">
      <button class="filter-btn active" data-jenjang="">Semua</button>
      {
        jenjangList.map((j) => (
          <button class="filter-btn" data-jenjang={j}>
            {j}
          </button>
        ))
      }
    </div>
  </div>

  <!-- Filter bar -->
  <div class="card mb-4 fade-up d1">
    <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
      <input
        id="searchInput"
        type="text"
        placeholder="Cari nama sekolah atau NPSN..."
        style="flex:1;min-width:200px;padding:8px 12px;border:1px solid var(--border-medium);border-radius:8px;font-size:13.5px;font-family:inherit;background:var(--bg-surface);color:var(--text-primary);outline:none"
      />

      <select id="filterKab" class="sel">
        <option value="">Semua Wilayah</option>
        {kabList.map((k) => <option value={k}>{k}</option>)}
      </select>

      <select id="filterAk" class="sel">
        <option value="">Semua Akreditasi</option>
        <option value="A">Akreditasi A</option>
        <option value="B">Akreditasi B</option>
        <option value="C">Akreditasi C</option>
        <option value="Tidak diisi">Belum Terakreditasi</option>
      </select>

      <select id="filterAN" class="sel">
        <option value="">Semua Status AN</option>
        <option value="ikut">Ikut AN</option>
        <option value="tidak">Tidak Ikut AN</option>
      </select>

      <select id="filterLogin" class="sel">
        <option value="">Semua Status Login</option>
        <option value="sudah">Sudah Akses</option>
        <option value="belum">Belum Akses</option>
      </select>

      <select id="filterUnduh" class="sel">
        <option value="">Semua Status Unduh</option>
        <option value="sudah">Sudah Unduh</option>
        <option value="belum">Belum Unduh</option>
      </select>

      <select id="filterPMP" class="sel">
        <option value="">Semua PMP</option>
        <option value="ya">Menerapkan PMP</option>
        <option value="tidak">Tidak Menerapkan</option>
      </select>

      <span
        id="countBadge"
        class="badge badge-gray"
        style="white-space:nowrap;flex-shrink:0">0 sekolah</span
      >
    </div>
  </div>

  <!-- Table -->
  <div class="card fade-up d2" style="padding:0;overflow:hidden">
    <div style="overflow-x:auto">
      <table class="data-table">
        <thead>
          <tr>
            <th style="cursor:pointer" data-sort="nama">Nama Sekolah</th>
            <th style="cursor:pointer" data-sort="kab">Wilayah</th>
            <th>Akreditasi</th>
            <th style="cursor:pointer;text-align:right" data-sort="siswa"
              >Siswa</th
            >
            <th style="cursor:pointer;text-align:right" data-sort="snp">SNP</th>
            <th>Status AN</th>
            <th>Status Login</th>
            <th>Status Unduh</th>
            <th>Status Alokasi</th>
            <th>PMP</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <div
    style="display:flex;align-items:center;justify-content:space-between;margin-top:14px"
    class="fade-up d3"
  >
    <div style="font-size:12.5px;color:var(--text-tertiary)" id="pageInfo">
    </div>
    <div style="display:flex;gap:6px">
      <button id="prevBtn" class="btn">← Prev</button>
      <button id="nextBtn" class="btn">Next →</button>
    </div>
  </div>
</DashboardLayout>

<style>
  .filter-btn {
    padding: 5px 14px;
    border-radius: 99px;
    border: 1px solid var(--border-strong);
    background: var(--bg-surface);
    color: var(--text-secondary);
    font-size: 12.5px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover {
    background: var(--bg-subtle);
    color: var(--text-primary);
  }
  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .sel {
    padding: 8px 12px;
    border: 1px solid var(--border-medium);
    border-radius: 8px;
    font-size: 13.5px;
    font-family: inherit;
    background: var(--bg-surface);
    color: var(--text-primary);
    cursor: pointer;
    outline: none;
  }
  .sel:focus {
    border-color: var(--accent);
  }
  input[type="text"]:focus {
    border-color: var(--accent) !important;
    outline: none;
  }
</style>

<script define:vars={{ sekolahData }}>
  document.addEventListener("DOMContentLoaded", () => {
    let filtered = [...sekolahData];
    let sortKey = "snp";
    let sortDir = -1;
    let page = 1;
    let curJenjang = "";
    const PER = 15;

    function sc(v) {
      if (v >= 75) return "#059669";
      if (v >= 60) return "#D97706";
      if (v > 0) return "#DC2626";
      return "#9CA3AF";
    }

    function badge(cls, text) {
      return `<span class="badge ${cls}">${text}</span>`;
    }

    function akBadge(ak) {
      const map = { A: "badge-blue", B: "badge-gray", C: "badge-amber" };
      return badge(map[ak] || "badge-gray", ak || "—");
    }

    function yaBadge(val, trueText = "Ya", falseText = "Tidak") {
      const isYa =
        typeof val === "string"
          ? val.toLowerCase().includes("ya") ||
            val.toLowerCase().includes("sudah") ||
            val.toLowerCase().includes("sesuai")
          : !!val;
      return isYa
        ? badge("badge-green", trueText)
        : badge("badge-gray", falseText);
    }

    function aloikasiBadge(val) {
      if (!val) return badge("badge-gray", "—");
      return val.toLowerCase().includes("sesuai") &&
        !val.toLowerCase().includes("belum")
        ? badge("badge-green", "Sesuai")
        : badge("badge-gray", "Belum Sesuai");
    }

    function pmpBadge(val) {
      if (!val) return badge("badge-gray", "—");
      return val.toLowerCase() === "ya"
        ? badge("badge-blue", "Menerapkan")
        : badge("badge-gray", "Tidak");
    }

    function render() {
      const start = (page - 1) * PER;
      const rows = filtered.slice(start, start + PER);

      document.getElementById("tbody").innerHTML = rows
        .map(
          (s) => `
        <tr>
          <td>
            <div style="font-weight:500;color:var(--text-primary)">${s.nama}</div>
            <div style="font-size:11.5px;color:var(--text-tertiary)">${s.npsn} · ${s.kec} · <strong>${s.jenjang}</strong></div>
          </td>
          <td style="font-size:13px;color:var(--text-secondary)">${s.kab}</td>
          <td>${akBadge(s.akreditasi)}</td>
          <td style="text-align:right;font-family:'JetBrains Mono',monospace;font-size:13px">${s.siswa || "—"}</td>
          <td style="text-align:right">
            <span style="font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:600;color:${sc(s.snp)}">${s.snp > 0 ? s.snp : "—"}</span>
          </td>
          <td>${yaBadge(s.statusAN, "Ikut AN", "Tidak")}</td>
          <td>${yaBadge(s.statusLogin, "Sudah Akses", "Belum")}</td>
          <td>${yaBadge(s.statusUnduh, "Sudah Unduh", "Belum")}</td>
          <td>${aloikasiBadge(s.statusAlokasi)}</td>
          <td>${pmpBadge(s.menerapkanPMP)}</td>
        </tr>
      `,
        )
        .join("");

      const total = Math.ceil(filtered.length / PER);
      document.getElementById("pageInfo").textContent =
        `Halaman ${page} dari ${total} · ${filtered.length} sekolah`;
      document.getElementById("prevBtn").disabled = page === 1;
      document.getElementById("nextBtn").disabled = page >= total;
      document.getElementById("countBadge").textContent =
        `${filtered.length} sekolah`;
    }

    function apply() {
      const q = document.getElementById("searchInput").value.toLowerCase();
      const kab = document.getElementById("filterKab").value;
      const ak = document.getElementById("filterAk").value;
      const an = document.getElementById("filterAN").value;
      const login = document.getElementById("filterLogin").value;
      const unduh = document.getElementById("filterUnduh").value;
      const pmp = document.getElementById("filterPMP").value;

      filtered = sekolahData.filter((s) => {
        if (curJenjang && s.jenjang !== curJenjang) return false;
        if (q && !s.nama.toLowerCase().includes(q) && !s.npsn.includes(q))
          return false;
        if (kab && s.kab !== kab) return false;
        if (ak && s.akreditasi !== ak) return false;
        if (an === "ikut" && s.statusAN !== "Ikut AN") return false;
        if (an === "tidak" && s.statusAN === "Ikut AN") return false;
        if (login === "sudah" && s.statusLogin !== "Sudah Akses") return false;
        if (login === "belum" && s.statusLogin === "Sudah Akses") return false;
        if (unduh === "sudah" && s.statusUnduh !== "Sudah Unduh") return false;
        if (unduh === "belum" && s.statusUnduh === "Sudah Unduh") return false;
        if (pmp === "ya" && (s.menerapkanPMP || "").toLowerCase() !== "ya")
          return false;
        if (pmp === "tidak" && (s.menerapkanPMP || "").toLowerCase() === "ya")
          return false;
        return true;
      });

      filtered.sort((a, b) => {
        const va = a[sortKey] || 0,
          vb = b[sortKey] || 0;
        return typeof va === "string"
          ? va.localeCompare(vb) * sortDir
          : (va - vb) * sortDir;
      });

      page = 1;
      render();
    }

    // Jenjang filter buttons
    document.querySelectorAll(".filter-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        document
          .querySelectorAll(".filter-btn")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        curJenjang = btn.dataset.jenjang;
        apply();
      });
    });

    // Sort headers
    document.querySelectorAll("[data-sort]").forEach((th) => {
      th.addEventListener("click", () => {
        if (sortKey === th.dataset.sort) sortDir *= -1;
        else {
          sortKey = th.dataset.sort;
          sortDir = -1;
        }
        apply();
      });
    });

    // Filter inputs
    [
      "searchInput",
      "filterKab",
      "filterAk",
      "filterAN",
      "filterLogin",
      "filterUnduh",
      "filterPMP",
    ].forEach((id) => {
      const el = document.getElementById(id);
      el.addEventListener("input", apply);
      el.addEventListener("change", apply);
    });

    // Pagination
    document.getElementById("prevBtn").addEventListener("click", () => {
      if (page > 1) {
        page--;
        render();
      }
    });
    document.getElementById("nextBtn").addEventListener("click", () => {
      if (page < Math.ceil(filtered.length / PER)) {
        page++;
        render();
      }
    });

    apply();
  });
</script>
